{
	"name": "@suki-suki-club/link-like-ui",
	"type": "module",
	"version": "0.1.0",
	"description": "A certain UI library that looks like Link-Like-OS.",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Suki-Suki-Club/link-like-ui.git"
	},
	"exports": {
		"./styles.css": "./dist/styles/index.css",
		"./*": {
			"types": "./dist/*/index.d.ts",
			"import": "./dist/*/index.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist"
	],
	"publishConfig": {
		"registry": "https://npm.pkg.github.com"
	},
	"scripts": {
		"build": "pnpm run build:js && pnpm run build:css && node ./scripts/build-style.mjs",
		"build:css": "tailwindcss -i ./src/styles/index.css -o ./dist/styles/index.css --minify",
		"build:js": "tsdown",
		"play": "vite",
		"generate:icons": "node ./scripts/generate-icons-index.mjs",
		"biome:check": "biome check --fix --error-on-warnings .",
		"biome:check:ci": "biome check --error-on-warnings .",
		"fix:tailwind-canonical": "node ./scripts/fix-tailwind-canonical.mjs",
		"lint:tailwind-canonical": "node ./scripts/fix-tailwind-canonical.mjs --check",
		"check": "pnpm run fix:tailwind-canonical && pnpm run biome:check",
		"check:ci": "pnpm run lint:tailwind-canonical && pnpm run biome:check:ci",
		"knip": "knip --exports",
		"typecheck": "tsc --noEmit",
		"changeset": "changeset",
		"version": "changeset version",
		"release": "changeset publish",
		"prebuild:js": "pnpm run generate:icons",
		"precheck": "pnpm run generate:icons",
		"precheck:ci": "pnpm run generate:icons",
		"preplay": "pnpm run generate:icons",
		"pretypecheck": "pnpm run generate:icons",
		"prepublishOnly": "pnpm run build",
		"prepare": "lefthook install"
	},
	"peerDependencies": {
		"react": "^19.2.0",
		"react-dom": "^19.2.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.14",
		"@changesets/changelog-github": "^0.7.0",
		"@changesets/cli": "^2.31.0",
		"@svgr/rollup": "^8.1.0",
		"@tailwindcss/cli": "^4.2.2",
		"@tailwindcss/node": "^4.2.2",
		"@tailwindcss/vite": "^4.2.1",
		"@tsconfig/strictest": "^2.0.8",
		"@types/node": "^25.0.3",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.2",
		"knip": "^5.83.1",
		"lefthook": "^2.1.0",
		"tailwindcss": "^4.2.1",
		"tsdown": "^0.18.1",
		"typescript": "^5.9.3",
		"vite": "^7.3.0",
		"vite-plugin-svgr": "^5.2.0"
	},
	"dependencies": {
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-radio-group": "^1.3.8",
		"@radix-ui/react-slider": "^1.3.6",
		"@radix-ui/react-tabs": "^1.1.13",
		"@radix-ui/react-toggle": "^1.1.10",
		"clsx": "^2.1.1",
		"react-icons": "^5.6.0",
		"simplebar": "^6.3.3",
		"simplebar-react": "^3.3.2",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"zustand": "^5.0.11"
	}
}
